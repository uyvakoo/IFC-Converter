# Python
.venv/
__pycache__/
*.pyc

# Build artifacts
build/
dist/
*.spec.bak

# Cython obfuscation output (scripts/obfuscate_licensing.py) — compiled licensing, never commit
*.pyd
licensing/*.c

# Release packages (produced by release.yml / make_release.ps1)
IFC_Converter-*.zip
*.zip.sha256

# Native binaries — fetched via scripts/fetch_binaries.py, never committed
bin/

# Vendored offline wheels — produced by scripts/vendor_wheels.py, never committed
wheels/

# Vendor RSA private key — MUST NEVER be committed or bundled
_vendor/

# Local outputs / logs
out/
tests/_out*/
acceptance_out/
*.log

# Coverage data
.coverage
.coverage.*
htmlcov/
